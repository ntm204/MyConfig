{
  // === Workbench & Window ===
  "workbench.colorTheme": "Experimental Dark",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.statusBar.visible": false,
  "workbench.activityBar.location": "hidden",
  "window.zoomLevel": 0,
  "window.commandCenter": false,

  // === Explorer ===
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": true,
  "explorer.confirmDelete": true,

  // === Editor Font & Cursor ===
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 13,
  "editor.fontLigatures": true,
  "editor.lineHeight": 2,
  "editor.letterSpacing": 1,
  "editor.cursorBlinking": "expand",
  "editor.cursorStyle": "line-thin",
  "editor.cursorSmoothCaretAnimation": "explicit",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.snippetSuggestions": "top",
  "editor.smoothScrolling": true,

  // === Editor Behavior ===
  "editor.stickyScroll.enabled": false,
  "editor.matchBrackets": "near",
  "editor.lineNumbers": "relative",
  "editor.tabSize": 4,
  "editor.detectIndentation": false,
  "editor.minimap.enabled": false,

  // === Editor Display & Scroll ===
  "editor.lightbulb.enabled": "onCode",
  "editor.renderWhitespace": "none",
  "editor.guides.indentation": true,
  "editor.renderLineHighlight": "none",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.scrollbar.verticalScrollbarSize": 5,
  "editor.scrollbar.horizontalScrollbarSize": 5,
  "editor.scrollBeyondLastLine": false,
  "editor.wordWrap": "on",
  "editor.quickSuggestionsDelay": 50,
  "editor.inlineSuggest.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.bracketPairColorization.enabled": true,
//   "editor.guides.bracketPairs": true,

  // === Editor Formatting ===
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[liquid]": { "editor.defaultFormatter": "Shopify.theme-check-vscode" },

  // === Color Customizations ===
  "workbench.colorCustomizations": {
    "editorOverviewRuler.findMatchForeground": "#00bcd400",
    "editorOverviewRuler.errorForeground": "#ff572200",
    "focusBorder": "#0000",
    "input.border": "#0000",
    "scrollbarSlider.background": "#ffffff28",
    "editorCursor.background": "#98d9d9",
    "tab.border": "#0000",
    "tab.activeBorder": "#0000",
    "tab.activeBorderTop": "#0000",
    "tab.inactiveBackground": "#0000",
    "tab.activeBackground": "#0000",
    "editorGroupHeader.tabsBorder": "#0000",
    "titleBar.border": "#0000"
  },

  // === Files ===
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSave": "afterDelay",

  // === Extensions ===
  "extensions.ignoreRecommendations": true,

  // === Code Runner ===
  "code-runner.runInTerminal": true,
  "git.enableSmartCommit": true,
  "security.workspace.trust.enabled": true,
  "workbench.panel.showLabels": false,
  "chat.viewSessions.orientation": "stacked"
}
